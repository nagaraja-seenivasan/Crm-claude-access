{
  "name": "crm-rule-builder-backend",
  "version": "1.0.0",
  "description": "CRM Rule Builder — LoopBack 4 API with SQS consumer",
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "lb-tsc",
    "build:watch": "lb-tsc --watch",
    "start": "node -r source-map-support/register .",
    "dev": "nodemon --watch src -e ts --exec \"npm run build && npm start\"",
    "clean": "lb-clean dist *.tsbuildinfo .eslintcache",
    "lint": "npm run eslint",
    "eslint": "eslint --report-unused-disable-directives ."
  },
  "dependencies": {
    "@loopback/boot": "^8.0.12",
    "@loopback/core": "^7.0.11",
    "@loopback/repository": "^8.0.11",
    "@loopback/rest": "^15.0.12",
    "@loopback/rest-explorer": "^8.0.12",
    "@loopback/service-proxy": "^8.0.11",
    "@aws-sdk/client-sqs": "^3.540.0",
    "loopback-connector-mongodb": "^7.0.4",
    "source-map-support": "^0.5.21",
    "tslib": "^2.6.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@loopback/build": "^12.0.11",
    "@loopback/eslint-config": "^14.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "nodemon": "^3.0.3",
    "typescript": "~5.3.3"
  }
}
